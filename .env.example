# Supabase (02_Workspace 공용 프로젝트와 동일 키를 쓰거나, 전용 프로젝트를 쓰면 해당 URL/키로 교체)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 프로덕션 사이트 URL (비밀번호 재설정 리다이렉트). 로컬 테스트 시 http://127.0.0.1:3010
# NEXT_PUBLIC_SITE_URL=https://bestvip77.com

# npm run admin:send-password-reset 대상 (기본 llangkka00@gmail.com)
# PASSWORD_RESET_EMAIL=

# 선택: `npm run admin:sync-portal` — 기본 관리자는 kstop12@nate.com, llangkka00@gmail.com (코드 기본값)
# 한 명만 쓰려면: PORTAL_ADMIN_EMAIL=one@example.com
# 여러 명: PORTAL_ADMIN_EMAILS=a@x.com,b@y.com
